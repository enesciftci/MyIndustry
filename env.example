# ===================
# MyIndustry - Dokploy Environment Variables
# ===================
# Copy these to Dokploy UI → Environment Variables section
# Replace the placeholder values with your actual credentials

# ===================
# PostgreSQL (Dokploy Built-in Database)
# ===================
DB_HOST=your-dokploy-database-hostname
DB_PASSWORD=your-database-password

# ===================
# Redis (Dokploy Built-in Redis)
# ===================
REDIS_HOST=your-dokploy-redis-hostname
REDIS_PASSWORD=your-redis-password
# Required for Api + Identity. Do not set ConnectionStrings__Redis manually in Dokploy.
# docker-compose.dokploy.yaml injects REDIS_HOST, REDIS_PASSWORD, and:
# ConnectionStrings__Redis=${REDIS_HOST}:6379,password=${REDIS_PASSWORD}
# After deploy, verify: docker exec myindustry-api printenv ConnectionStrings__Redis

# ===================
# RabbitMQ (Separate Compose)
# ===================
RABBITMQ_HOST=your-rabbitmq-container-name
RABBITMQ_USER=your-rabbitmq-username
RABBITMQ_PASSWORD=your-rabbitmq-password
