# ===================
# MyIndustry - Dokploy Environment Variables
# ===================
# App stack → Environment (project-level). No spaces after =.
# docker-compose.dokploy.yaml maps these to service env vars.
# Migration guide: DOKPLOY-ENV.md | Checklist: SECURITY.md

# ===================
# JWT (Api, Identity, Gateway — same key, min 32 characters)
# ===================
JWT_SIGNING_KEY=YourSecureRandomKeyAtLeast32CharsLong
JWT_ISSUER=MyIndustry.Identity

# ===================
# CORS and host filtering (Api, Identity, Gateway)
# ===================
CORS_ALLOWED_ORIGIN=https://your-frontend-domain.com
ALLOWED_HOSTS=gateway.your-domain.com;api.your-domain.com
# Second origin (www): add Cors__AllowedOrigins__1 on each service in Dokploy, or redirect www → apex

# ===================
# Internal API key (Api; Identity uses it to call Main API)
# ===================
INTERNAL_API_KEY=your-strong-random-api-key

# ===================
# Identity admin seed and password reset (first deploy)
# ===================
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=YourSecureAdminPassword
PASSWORD_RESET_ALLOWED_BASE_URL=https://your-frontend-domain.com

# ===================
# PostgreSQL (Dokploy Built-in Database)
# ===================
DB_HOST=myindustry-database-ss66da
DB_PASSWORD=your-database-password
# Do NOT set ConnectionStrings__MyIndustry — compose builds it from DB_HOST + DB_PASSWORD

# ===================
# Redis (Dokploy Built-in Redis)
# ===================
REDIS_HOST=myindustry-redis-kmrpdg
REDIS_PASSWORD=your-redis-password
# Do NOT set ConnectionStrings__Redis — compose injects it for Api + Identity

# ===================
# RabbitMQ (Separate Compose)
# ===================
RABBITMQ_HOST=your-rabbitmq-container-name
RABBITMQ_USER=your-rabbitmq-username
RABBITMQ_PASSWORD=your-rabbitmq-password

# ===================
# Optional
# ===================
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# ===================
# R2 — Api service ONLY (add in Dokploy on myindustry-api, not project env if not injected)
# Use R2__SecretAccessKey (NOT R2__SecretKey). No trailing commas on values.
# ===================
# R2__AccountId=your-cloudflare-account-id
# R2__AccessKeyId=your-r2-access-key-id
# R2__SecretAccessKey=your-r2-secret-access-key
# R2__BucketName=myindustry-uploads
# R2__PublicBaseUrl=https://pub-xxxx.r2.dev

# After deploy, verify:
# docker exec myindustry-api printenv | grep -iE 'Jwt|Cors|Allowed|REDIS|ConnectionStrings|R2'
# docker logs myindustry-api --tail 30
