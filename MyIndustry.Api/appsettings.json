{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
  "AllowedOrigins": [
    "http://localhost:3000",
    "https://localhost:3000"
  ]
},
  "ForwardedHeaders": {
    "KnownProxies": []
  },
  "R2": {
    "AccountId": "",
    "AccessKeyId": "",
    "SecretAccessKey": "",
    "BucketName": "uploads",
    "PublicBaseUrl": ""
  },
  "Jwt": {
    "SigningKey": ""
  },
  "MediatRLogging": {
  "Enabled": true,
  "LogRequestPayload": true,
  "MaxStringLength": 256,
  "MaskEmails": true,
  "MaskPhones": true
}
}
